# Copy this file to server/.env and adjust as needed.

# Set to `production` behind an HTTPS proxy (ALB/nginx) — enables Secure cookies.
NODE_ENV=development

# Port the API + Socket.io server listens on.
PORT=4000

# MongoDB connection string.
#   Local (node on host):  mongodb://127.0.0.1:27017/pulse
#   In Docker (compose):   mongodb://mongo:27017/pulse   <-- service name, NOT 127.0.0.1
#   Atlas:                 mongodb+srv://<user>:<pass>@<cluster>/pulse
MONGO_URI=mongodb://127.0.0.1:27017/pulse

# Origin allowed to connect (the client). In production:
#   CLIENT_ORIGIN=https://pulse.tradyai.live
CLIENT_ORIGIN=http://localhost:5173

# Secret used to sign session cookies. MUST be set to a long random value in
# production (e.g. `openssl rand -base64 48`).
SESSION_SECRET=pulse-dev-secret-change-me

# Max votes one IP may cast per round (anti-ballot-stuffing ceiling).
MAX_VOTES_PER_IP=5

# Ambient bots keep the world alive when few/no humans are around.
# Set BOTS_ENABLED=false to disable them entirely.
BOTS_ENABLED=true
BOTS_MIN=4
BOTS_MAX=22
BOTS_CHURN=3
BOT_POOL=60
