# Copy this file to server/.env and adjust as needed.

# Port the API + Socket.io server listens on.
PORT=4000

# MongoDB connection string.
#   Local:  mongodb://127.0.0.1:27017/pulse
#   Atlas:  mongodb+srv://<user>:<pass>@<cluster>/pulse
MONGO_URI=mongodb://127.0.0.1:27017/pulse

# Origin allowed to connect (the Vite client).
CLIENT_ORIGIN=http://localhost:5173

# Secret used to sign session cookies. MUST be set to a long random value in
# production (e.g. `openssl rand -base64 48`).
SESSION_SECRET=pulse-dev-secret-change-me

# Max votes one IP may cast per round (anti-ballot-stuffing ceiling).
MAX_VOTES_PER_IP=5
